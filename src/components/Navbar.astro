---
const { sections } = Astro.props as { sections: Section[] };
---

<div
    class="navbar md:justify-center fixed top-0 left-0 right-0 z-50 shadow-sm bg-gray-950/60 backdrop-blur-md border-b border-gray-800 transition-all duration-300"
>
    <div class="navbar-start md:hidden">
        <div class="dropdown">
            <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h8m-8 6h16"></path>
                </svg>
            </div>
            <ul
                tabindex="-1"
                class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow"
            >
                {
                    sections?.map((section) => (
                        <li>
                            <a
                                href={section.reference}
                                class="py-2 px-3 relative text-gray-400 hover:text-emerald-400 transition-all duration-300
                                    after:absolute after:bottom-0.5 after:left-0 after:h-0.5 after:w-0
                                    after:bg-emerald-400 after:transition-all after:duration-300 hover:after:w-full"
                            >
                                {section.name}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
    <div class="navbar-center hidden md:inline-flex">
        {
            sections?.map((section) => (
                <a
                    href={section.reference}
                    class="py-2 px-3 relative text-gray-400 hover:text-emerald-400 transition-all duration-300
                            after:absolute after:bottom-0.5 after:left-0 after:h-0.5 after:w-0
                            after:bg-emerald-400 after:transition-all after:duration-300 hover:after:w-full"
                >
                    {section.name}
                </a>
            ))
        }
    </div>
</div>
