---
import { useData } from "@utils/i18n"

const { experience } = useData(Astro.currentLocale ?? "es");

function renderClass(index: number) {
    return index % 2 === 0 ? "timeline-start md:text-end" : "timeline-end";
}
---
<ul class="timeline timeline-snap-icon max-md:timeline-compact timeline-vertical">
    {
        experience.map((item, index) => (
            <li>
                <div class="timeline-middle">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                        class={"w-7 h-7 " + (item.current ? "text-primary" : "text-gray-400")}
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                            clip-rule="evenodd"></path>
                    </svg>
                </div>
                <div class={renderClass(index) + " mb-10"}>
                    <time class="font-mono italic">{item.time}</time>
                    <div class="text-lg font-black">{item.title}</div>
                    {
                        item.place && (<div class="text-sm italic">{item.place}</div>)
                    }
                    <ul class="list-disc list-inside mt-2">
                        {
                            item.functions.map(func => (<li>{func}</li>))
                        }
                    </ul>
                </div>
            </li>
        ))
    }
</ul>
