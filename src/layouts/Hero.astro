---
import Typed from "@components/vue/Typed.vue";
import { useTranslations } from "@utils/i18n";

const t = useTranslations(Astro.currentLocale ?? "es");
---

<div class="hero min-h-screen bg-image">
    <div class="hero-overlay"></div>
    <div class="hero-content text-neutral-content text-center">
        <div class="space-y-4 px-4">
            <h1 class="text-5xl md:text-7xl font-bold">{t("messages.home.title")}</h1>
            <div class="bg-gray-900/60 backdrop-blur-md rounded-lg border border-gray-700/50 shadow-lg max-w-lg mx-auto px-5 py-4 mt-10">
                <Typed 
                    client:visible
                    texts={t("messages.home.subtitles").split(",")}
                    pretext={t("messages.home.pretext")}
                />
            </div>
        </div>
    </div>
</div>
