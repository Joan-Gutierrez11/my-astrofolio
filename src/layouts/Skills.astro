---
import DecodeText from "@components/vue/DecodeText.vue";
import { useTranslations } from "@utils/i18n";
import { capitalize } from "@utils/utilities";
import esData from "@data/es.json";
import enData from "@data/en.json";

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);
const { skills } = lang === "es" ? esData : enData;

const categories = [
    { key: 'backend', label: t('messages.skills.backend') },
    { key: 'frontend', label: t('messages.skills.frontend') },
];
---

<div class="bg-base-200 min-h-screen flex flex-col items-center py-16">
    <div class="w-full px-4 mt-10">
        <h2 class="text-4xl font-bold mb-4 text-center">
            <DecodeText 
                client:visible 
                text={t("messages.skills.title")} 
                revealSpeed={1}
                frameDelay={50}
            />
        </h2>
    </div>
    <div class="max-w-5xl mx-auto px-4 mt-10 space-y-16 w-full">
        {
            categories.map(({ key, label }) => {
                const items = skills[key as keyof typeof skills];
                return (
                    <div>
                        <h3 class="text-2xl font-semibold mb-8 text-center text-primary">
                            {label}
                        </h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                            {
                                items.map((skill) => (
                                    <div class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow duration-300 p-6 flex flex-col items-center gap-3">
                                        <i class={`devicon-${skill}-plain text-5xl`}></i>
                                        <span class="text-sm font-medium">{capitalize(skill)}</span>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                );
            })
        }
    </div>
</div>
