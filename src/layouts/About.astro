---
import DecodeText from "@components/vue/DecodeText.vue";
import photo from "@assets/images/personal-photo.jpg";
import { useData, useTranslations } from "@utils/i18n";

const t = useTranslations(Astro.currentLocale ?? "es");
const { about } = useData(Astro.currentLocale ?? "es");
const cvDownloadUrl = import.meta.env.CV_DOWNLOAD_URL ?? '#';
---
<div class="hero bg-base-200 min-h-screen">
    <div class="hero-content flex-col lg:flex-row gap-20 px-20">
        <img
            src={photo.src}
            class="w-3/4 md:w-1/2 lg:max-w-sm rounded-lg shadow-2xl"
            fetchpriority="high"
            alt="Photo"
        />
        <div>
            <h1 class="text-5xl font-bold">
                <DecodeText 
                    client:visible 
                    text={about.title}
                    revealSpeed={2}
                    frameDelay={50}
                />
            </h1>
            <p class="py-6 text-sm">
                {about.description}
            </p>
            <a
                href={cvDownloadUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-outline"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                {t("messages.about_me.download_cv")}
            </a>
        </div>
    </div>
</div>
