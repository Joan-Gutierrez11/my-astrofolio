{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
        "@layouts/*": [
            "./src/layouts/*"
        ],
        "@styles/*": [
            "./src/styles/*"
        ],
        "@components/*": [
            "./src/components/*"
        ],
        "@pages/*": [
            "./src/pages/*"
        ],
        "@assets/*": [
            "./src/assets/*"
        ],
        "@i18n/*": [
            "./src/i18n/*"
        ],
        "@utils/*": [
            "./src/utils/*"
        ]
    }
  }
}
